# Временная метка публикации статуса.
# Нужна для журналирования, UI и внешних мониторинговых систем.
builtin_interfaces/Time stamp

# Имя активной или последней загруженной миссии.
# Позволяет оператору понять, какой YAML-маршрут сейчас выполняется.
string mission_name

# Строковое представление состояния mission state machine.
# Значения ожидаются в стиле IDLE, NAVIGATING, FAILED и т.д.
string state

# Флаг, показывающий, считает ли mission manager миссию активной прямо сейчас.
bool active

# Индекс текущей waypoint в списке маршрута.
# Удобен для отладки и для привязки к исходному YAML.
uint32 current_waypoint_index

# Человекочитаемое имя текущей waypoint.
string current_waypoint_name

# Сколько точек уже завершилось успехом в рамках текущего прохода маршрута.
uint32 completed_waypoints

# Сколько точек завершилось ошибкой после исчерпания допустимых повторов.
uint32 failed_waypoints

# Сколько полных циклов маршрута уже прошло.
# Особенно полезно при loop_forever=true.
uint32 loop_count

# Сколько повторных попыток уже было использовано для текущей точки.
uint32 retry_count_for_current_waypoint

# Последняя человекочитаемая ошибка или причина остановки миссии.
string last_error
