<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="patrolbot">
  <!--
    Геометрические параметры вынесены в свойства, чтобы подгонять модель под
    реальное шасси без переписывания всех origin, box и cylinder вручную.
    На первом этапе это даёт один понятный набор размеров для всей модели.
  -->
  <xacro:property name="base_length" value="0.32"/>
  <xacro:property name="base_width" value="0.24"/>
  <xacro:property name="base_height" value="0.10"/>
  <xacro:property name="wheel_radius" value="0.05"/>
  <xacro:property name="wheel_thickness" value="0.03"/>
  <xacro:property name="wheel_offset_y" value="0.12"/>
  <xacro:property name="wheel_offset_x" value="0.0"/>
  <xacro:property name="wheel_offset_z" value="0.05"/>
  <xacro:property name="laser_offset_x" value="0.12"/>
  <xacro:property name="laser_offset_z" value="0.14"/>

  <!--
    base_footprint используется как плоская опорная система координат для
    навигации. Именно его обычно используют planner, costmap и AMCL.
  -->
  <link name="base_footprint"/>

  <!--
    base_link описывает физический корпус робота. От него подвешены колёса,
    LiDAR и остальные потенциальные датчики. Размеры и инерция выбраны как
    правдоподобная стартовая модель для компактной indoor-платформы.
  -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.3 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 ${base_height / 2.0}" rpy="0 0 0"/>
      <mass value="4.5"/>
      <inertia ixx="0.06" ixy="0.0" ixz="0.0" iyy="0.08" iyz="0.0" izz="0.10"/>
    </inertial>
  </link>

  <!--
    Переход между base_footprint и base_link фиксированный. Это отделяет
    навигационный "плоский" frame от реального объёма корпуса.
  -->
  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!--
    Левое колесо выделено в отдельное звено с continuous-joint. Это нужно для
    публикации joint_states, корректной визуализации и понятной кинематики.
  -->
  <link name="left_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!--
    Ось вращения направлена вдоль Y, потому что геометрия колеса уже повернута
    и должна соответствовать кинематике дифференциальной базы.
  -->
  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin xyz="${wheel_offset_x} ${wheel_offset_y} ${wheel_offset_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!--
    Правое колесо описано отдельно, хотя почти симметрично левому. Для маленькой
    модели это удобнее читать и править вручную, чем скрывать в макросах.
  -->
  <link name="right_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
      <material name="black"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
      <geometry>
        <cylinder radius="${wheel_radius}" length="${wheel_thickness}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.4"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <!--
    Правое колесо смещено в отрицательную сторону по Y относительно центра базы.
  -->
  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin xyz="${wheel_offset_x} -${wheel_offset_y} ${wheel_offset_z}" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!--
    laser_frame выделен в отдельное звено, чтобы внешний LiDAR-драйвер публиковал
    данные в самостоятельный понятный frame, а не прямо в base_link.
  -->
  <link name="laser_frame">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.05"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.05"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.2"/>
      <inertia ixx="0.0002" ixy="0.0" ixz="0.0" iyy="0.0002" iyz="0.0" izz="0.0002"/>
    </inertial>
  </link>

  <!--
    LiDAR вынесен немного вперёд и вверх, чтобы уменьшить экранирование корпусом
    и получить более полезный обзор для indoor-навигации и SLAM.
  -->
  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_frame"/>
    <origin xyz="${laser_offset_x} 0 ${laser_offset_z}" rpy="0 0 0"/>
  </joint>
</robot>
